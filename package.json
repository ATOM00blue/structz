{
  "name": "structz",
  "version": "0.1.0",
  "description": "Convert and query between JSON, YAML, CSV, and TOML from the CLI or a tiny in-browser playground.",
  "keywords": [
    "json",
    "yaml",
    "csv",
    "toml",
    "cli",
    "converter",
    "convert",
    "query",
    "jsonpath",
    "data",
    "yq",
    "jq",
    "transform"
  ],
  "homepage": "https://atom00blue.github.io/structz/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ATOM00blue/structz.git"
  },
  "bugs": {
    "url": "https://github.com/ATOM00blue/structz/issues"
  },
  "license": "MIT",
  "author": "ATOM00blue",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "structz": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:playground": "node scripts/build-playground.mjs",
    "build:all": "npm run build && npm run build:playground",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "node scripts/smoke.mjs",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "papaparse": "^5.4.1",
    "smol-toml": "^1.3.1",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/papaparse": "^5.3.15",
    "esbuild": "^0.28.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.7"
  }
}
